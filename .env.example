# Copier vers .env en local (ne pas committer .env).
# Sur Vercel : Project → Settings → Environment Variables (Production / Preview).

# Obligatoire pour activer AdSense : ton ID éditeur
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Optionnel : désactiver la pub (valeur littérale off)
# VITE_ADSENSE_CLIENT=off

# Optionnel : IDs numériques des blocs « Annonce display » créés dans AdSense
# (Annonces par unité → Blocs d’annonces). Sans ces variables, seul le script
# est chargé après consentement → tu peux activer les annonces automatiques dans AdSense.
# VITE_ADSENSE_SLOT_MENU=1234567890
# VITE_ADSENSE_SLOT_MENU_SECOND=0987654321
# (ancien nom encore pris en charge : VITE_ADSENSE_SLOT_MENU_BOTTOM)
# VITE_ADSENSE_SLOT_GAME_SIDEBAR=1122334455
